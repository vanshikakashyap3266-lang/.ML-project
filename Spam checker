<!DOCTYPE html>
<html>
<head>
    <title>Spam Checker</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* 🔹 Background Image + Light Blur */
        body::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 100%;
            background: url("/static/bg.jpg") no-repeat center center/cover;
            filter: blur(3px) brightness(0.7);
            z-index: -1;
        }

        .card {
            background: rgba(255, 255, 255, 0.95);
            padding: 30px;
            width: 420px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.4);
        }

        .title-box {
            background: black;
            color: white;
            padding: 12px;
            margin-bottom: 15px;
            border-radius: 0px;
            font-size: 20px;
            font-weight: bold;
        }

        textarea {
            width: 100%;
            height: 120px;
            border-radius: 8px;
            border: 1px solid #ccc;
            padding: 10px;
            outline: none;
            resize: none;
        }

        textarea:focus {
            border-color: black;
        }

        button {
            margin-top: 15px;
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: black;
            color: white;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background: #333;
        }

        .result {
            margin-top: 20px;
            font-size: 18px;
            font-weight: bold;
        }
    </style>
</head>

<body>

<div class="card">

    <div class="title-box">
        Email Spam Detection
    </div>

    <form method="POST" action="/predict">
        <textarea name="message" placeholder="Check the message..."></textarea>
        <button type="submit">Check</button>
    </form>

    {% if prediction %}
        <div class="result">
            {{ prediction }}
        </div>
    {% endif %}

</div>

</body>
</html>spam
